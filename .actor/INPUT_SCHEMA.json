{
  "title": "Glassdoor Scraper Input",
  "description": "Configuration for Glassdoor job scraping",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "queries": {
      "title": "Search Queries",
      "type": "array",
      "description": "Job search queries for Glassdoor",
      "items": { "type": "string" },
      "editor": "stringList"
    },
    "location": {
      "title": "Location",
      "type": "string",
      "description": "Job location filter",
      "default": "United States",
      "editor": "textfield"
    },
    "maxJobs": {
      "title": "Maximum Jobs",
      "type": "integer",
      "description": "Maximum number of jobs to scrape",
      "default": 30,
      "minimum": 1,
      "maximum": 500
    }
  },
  "required": ["queries"]
}